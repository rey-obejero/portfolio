  <script>
    (function () {
      var checkbox = document.getElementById('theme-swap');
      var saved = localStorage.getItem('theme');
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

      checkbox.checked = saved === 'portfolio-dark' || (!saved && prefersDark);

      checkbox.addEventListener('change', function () {
        var theme = this.checked ? 'portfolio-dark' : 'portfolio-light';
        localStorage.setItem('theme', theme);
        document.documentElement.setAttribute('data-theme', theme);
      });

      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function (e) {
        if (!localStorage.getItem('theme')) {
          var theme = e.matches ? 'portfolio-dark' : 'portfolio-light';
          checkbox.checked = e.matches;
          document.documentElement.setAttribute('data-theme', theme);
        }
      });
    })();
  </script>
